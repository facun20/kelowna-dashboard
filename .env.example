# ── Kelowna Intel — Environment Variables ────────────────
# Copy to .env and fill in your values

# RapidAPI key (used for news aggregation)
RAPIDAPI_KEY=your_rapidapi_key

# AviationStack API key (free tier, 100 req/month)
AVIATIONSTACK_KEY=your_aviationstack_key

# Apify API token (for Realtor.ca scraping)
APIFY_API_TOKEN=your_apify_token

# SQLite database path (default: ./kelowna.db, in Docker: /data/kelowna.db)
# DB_PATH=/data/kelowna.db
